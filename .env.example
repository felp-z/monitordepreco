# Token do Bot do Telegram (Criado via @BotFather)
TELEGRAM_BOT_TOKEN=seu_bot_token_aqui

# Chat ID do Telegram para receber as mensagens (Use o utilitário get_chat_id para capturar)
TELEGRAM_CHAT_ID=seu_chat_id_aqui

# API Key do Firecrawl (Opcional, para fallback em sites com anti-bot agressivo)
FIRECRAWL_API_KEY=sua_api_key_do_firecrawl_aqui
